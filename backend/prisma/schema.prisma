generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model incentive_rules {
  id          String   @id
  action_type String   @unique
  amount_inr  Int
  createdAt   DateTime @default(now())
}

model question_responses {
  id            String @id
  visit_id      String
  question_id   String
  question_text String
  response      String
  visits        visits @relation(fields: [visit_id], references: [id], onDelete: Cascade)

  @@index([visit_id])
}

model visits {
  id                 String               @id
  worker_id          String
  patient_type       String
  patient_age_months Int?
  chief_complaint    String
  triage_result      String
  advice_given       Json
  referral_required  Boolean
  referral_urgency   String
  latitude           Float?
  longitude          Float?
  visit_timestamp    DateTime
  synced             Boolean              @default(true)
  sync_attempts      Int                  @default(0)
  server_received_at DateTime             @default(now())
  question_responses question_responses[]
  workers            workers              @relation(fields: [worker_id], references: [id])
  worker_earnings    worker_earnings?

  @@index([visit_timestamp])
  @@index([worker_id])
}

model worker_earnings {
  id            String   @id
  worker_id     String
  visit_id      String?  @unique
  action_type   String
  amount_inr    Int
  calculated_at DateTime @default(now())
  visits        visits?  @relation(fields: [visit_id], references: [id])
  workers       workers  @relation(fields: [worker_id], references: [id])

  @@index([worker_id])
}

model workers {
  id              String            @id
  name            String
  block           String
  district        String
  pin_hash        String
  role            WorkerRole
  createdAt       DateTime          @default(now())
  visits          visits[]
  worker_earnings worker_earnings[]
}

enum WorkerRole {
  WORKER
  SUPERVISOR
}
